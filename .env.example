# mitmproxy configuration.
# Copy this file to ".env" and edit. The start scripts (start-mitmproxy.sh /
# start-mitmproxy.bat) load ".env" automatically from the script directory.
#
# Notes:
#   - Lines starting with "#" are comments.
#   - In start-mitmproxy.sh the file is sourced by the shell, so quote any
#     value that contains spaces or special characters, e.g. PASS="p@ss w0rd".
#   - Values already present in the real environment take precedence over .env.

# --- Proxy authentication -------------------------------------------------
# Require a username/password to use the proxy (mitmproxy "proxyauth").
# Set MITM_PROXY_PASS to enable it; leave it EMPTY to disable authentication.
# When enabled, the Android device's proxy settings must supply these
# credentials (host proxy field: user:pass@host or the proxy auth dialog).
MITM_PROXY_USER=mitmproxy
MITM_PROXY_PASS=

# --- Ports / image (optional) ---------------------------------------------
# Proxy listen port.
PROXY_PORT=8080
# Web UI port (used by "web" mode / mitmweb).
WEB_PORT=8081
# Docker image to run.
IMAGE=mitmproxy/mitmproxy
